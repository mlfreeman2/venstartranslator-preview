{
	"name": ".NET 10 DevContainer with Claude Code (Ubuntu)",
	"build": {
		"dockerfile": "Dockerfile",
		"args": {
			"VARIANT": "10.0"
		}
	},
	"customizations": {
		"vscode": {
			"extensions": [
				"ms-dotnettools.csharp",
				"ms-dotnettools.csdevkit",
				"ms-azuretools.vscode-docker",
				"redhat.vscode-yaml",
				"eamodio.gitlens",
				"jeremycaron.csharp-organize-usings",
				"EditorConfig.EditorConfig",
				"github.vscode-github-actions",
				"Anthropic.claude-code"
			],
			"settings": {
				"terminal.integrated.defaultProfile.linux": "bash",
				"dotnet.defaultSolution": "${workspaceFolder}/*.sln"
			}
		}
	},
	"mounts": [
		// SSH keys for git operations
		"source=${localEnv:HOME}${localEnv:USERPROFILE}/.ssh,target=/home/vscode/.ssh,type=bind,readonly",
		// Claude Code auth + config + memory, SHARED across all local devcontainers
		// (one login everywhere; CLAUDE_CONFIG_DIR below must point at the target)
		"source=claude-code-shared,target=/home/vscode/.claude,type=volume",
		// NuGet package cache to speed up builds
		"source=${localEnv:HOME}${localEnv:USERPROFILE}/.nuget,target=/home/vscode/.nuget,type=bind,consistency=cached",
		// GitHub CLI auth persistence (survives container rebuilds)
		"source=${localEnv:HOME}${localEnv:USERPROFILE}/.config/gh,target=/home/vscode/.config/gh,type=bind,consistency=cached",
		// .NET User Secrets persistence
		"source=${localEnv:HOME}${localEnv:USERPROFILE}/.microsoft/usersecrets,target=/home/vscode/.microsoft/usersecrets,type=bind,consistency=cached"
	],
	"runArgs": [
		"--network=host"
	],
	"forwardPorts": [8080],
	"remoteEnv": {
		"PATH": "${containerEnv:PATH}:/home/vscode/.dotnet/tools",
		"TZ": "${localEnv:TZ:-America/New_York}",
		"DOTNET_CLI_TELEMETRY_OPTOUT": "1",
		"DOTNET_NOLOGO": "true"
	},
	"remoteUser": "vscode",
	"features": {
		"ghcr.io/devcontainers/features/common-utils:2": {
			"installZsh": true,
			"configureZshAsDefaultShell": false,
			"installOhMyZsh": true,
			"upgradePackages": false,
			"username": "vscode",
			"userUid": "automatic",
			"userGid": "automatic"
		},
		"ghcr.io/devcontainers/features/git:1": {
			"version": "latest",
			"ppa": false
		},
		"ghcr.io/devcontainers/features/github-cli:1": {}
	},
	// post-create runs as vscode and uses sudo internally only where root is required
	"postCreateCommand": "bash .devcontainer/post-create.sh",
	"postStartCommand": "claude --version || sudo npm install -g @anthropic-ai/claude-code",
	"updateContentCommand": "dotnet restore 2>/dev/null || true",
	"containerEnv": {
		"ASPNETCORE_ENVIRONMENT": "Development",
		// No ASPNETCORE_URLS: the app's port comes from its Kestrel appsettings section
		"CLAUDE_CONFIG_DIR": "/home/vscode/.claude"
	}
}
