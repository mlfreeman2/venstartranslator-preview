#!/usr/bin/env bash
# Run a local Home Assistant instance (http://localhost:8123) with this
# integration mounted. First run creates config/ and walks through HA
# onboarding; add the integration via Settings > Devices & Services.
#
# The listener needs traffic to decode: run scripts/replay_fixtures.py in a
# second terminal to broadcast the golden fixture packets to UDP 5001 inside
# the container's network namespace.
set -e
cd "$(dirname "$0")/.."

mkdir -p config/custom_components
if [ ! -f config/configuration.yaml ]; then
  cat > config/configuration.yaml <<'EOF'
default_config:
logger:
  default: info
  logs:
    custom_components.venstar_acc_tsenwifi_listener: debug
EOF
fi
ln -sfn "$(pwd)/custom_components/venstar_acc_tsenwifi_listener" config/custom_components/venstar_acc_tsenwifi_listener

exec hass -c config --debug
