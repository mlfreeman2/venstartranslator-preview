#!/usr/bin/env bash
# Run a local Home Assistant instance (http://localhost:8123) with this
# integration mounted. First run creates config/ and walks through HA
# onboarding; add the integration via Settings > Devices & Services.
#
# NOTE: UDP broadcasts stay inside the container's network namespace unless
# the container runs with host networking. That is fine for protocol
# development (a listener in the same container sees them), but broadcasts
# will not reach a physical thermostat from the default devcontainer setup.
set -e
cd "$(dirname "$0")/.."

mkdir -p config/custom_components
if [ ! -f config/configuration.yaml ]; then
  cat > config/configuration.yaml <<'EOF'
default_config:
logger:
  default: info
  logs:
    custom_components.venstar_acc_tsenwifi_emulator: debug
EOF
fi
ln -sfn "$(pwd)/custom_components/venstar_acc_tsenwifi_emulator" config/custom_components/venstar_acc_tsenwifi_emulator

exec hass -c config --debug
